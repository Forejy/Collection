extends layout

block content
  section
    header.category-header
      h1= name
    section.item-list
      each item in items
        article
          div= item.name
          div= item.edition
          img(class="item-image" src= item.image)
          div Price: #{item.price}
          div Stock: #{item.stock}
          div Condition: #{item.condition}
          div Shop: #{item.user_id}

